rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      // Solo l'utente autenticato può leggere e modificare il proprio documento
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // NOTA: Le Cloud Functions usano Firebase Admin SDK che bypassa queste rules per design.
      // NON aggiungere eccezioni per request.auth == null: è una falla di sicurezza.
    }

    match /tasks/{taskId} {
      allow read, write: if request.auth != null
                         && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
    }

    match /kpiEntries/{entryId} {
      allow read, write: if request.auth != null
                         && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
    }
  }
}
