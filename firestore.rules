rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Subcollection deferrals (task rimandati)
      match /deferrals/{dayId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /tasks/{taskId} {
      allow read, write: if request.auth != null
                         && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
    }

    match /kpiEntries/{entryId} {
      allow read, write: if request.auth != null
                         && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
    }

    // Diagnostics auth: scrittura aperta anche a utenti non loggati
    // (cattura errori PRIMA del login). Lettura solo da Firebase Console.
    match /auth_diagnostics/{docId} {
      allow create: if true;
      allow read, update, delete: if false;
    }
  }
}
